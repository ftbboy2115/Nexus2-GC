# Nexus 2 Environment Configuration
# Copy this file to .env and fill in your API keys

# Financial Modeling Prep (primary data source)
FMP_API_KEY=your_fmp_api_key_here

# Alpaca (intraday data, real-time quotes)
ALPACA_KEY=your_alpaca_key_here
ALPACA_SECRET=your_alpaca_secret_here

# Trading Mode
# SIMULATION = PaperBroker (local simulation, no external API)
# PAPER = AlpacaBroker paper trading (Alpaca paper-api, no real money)
# LIVE = AlpacaBroker live trading (⚠️ REAL MONEY - requires explicit confirmation)
# IMPORTANT: Default is SIMULATION. PAPER/LIVE require Alpaca credentials above.
TRADING_MODE=SIMULATION

# Database (optional, for persistence)
# DATABASE_URL=sqlite:///nexus2.db

# Trade Management Settings
PARTIAL_EXIT_FRACTION=0.5  # 0.5 = 1/2, 0.33 = 1/3
PARTIAL_EXIT_DAYS=3        # Days before partial exit eligible
PARTIAL_EXIT_GAIN_PCT=10   # Min gain % for partial exit

# Notifications (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

